# ===== LLM 大模型配置 =====
LLM_PROVIDER=openai
LLM_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=your-api-key-here
LLM_MODEL=qwen-plus
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096
LLM_TIMEOUT=120

# ===== Embedding 嵌入模型配置 =====
EMBEDDING_PROVIDER=openai
EMBEDDING_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_API_KEY=your-api-key-here
EMBEDDING_MODEL=text-embedding-3-large
EMBEDDING_DIM=1536
EMBEDDING_BATCH_SIZE=100

# ===== 数据库配置 =====
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/financial_agent
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=10

# ===== Redis 配置 =====
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_MAX_CONNECTIONS=50

# ===== 向量数据库配置 =====
VECTORSTORE_TYPE=chroma
CHROMA_PERSIST_DIR=./data/chromadb
CHROMA_COLLECTION_NAME=financial_knowledge

# ===== RAG 检索配置 =====
RAG_TOP_K=10
RAG_SCORE_THRESHOLD=0.5
RAG_RERANK_TOP_K=5
RAG_MAX_CONTEXT_LENGTH=8000

# ===== Agent 配置 =====
AGENT_MAX_ITERATIONS=10
AGENT_EARLY_STOP_THRESHOLD=0.8
AGENT_TOOL_CALL_TIMEOUT=30
AGENT_MEMORY_TYPE=buffer

# ===== DataOps 配置 =====
DATAOPS_PREFECT_API=http://localhost:4200/api
DATAOPS_WIND_TOKEN=
DATAOPS_TUSHARE_TOKEN=
DATAOPS_ETL_SCHEDULE_CRON="0 2 * * *"

# ===== LLMOps 监控配置 =====
LLMOPS_PROMETHEUS_PORT=9090
LLMOPS_ENABLE_METRICS=true
LLMOPS_LOG_FILE=./logs/llm_requests.log

# ===== 安全配置 =====
SECRET_KEY=change-this-to-a-random-secret-key-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# ===== 应用配置 =====
APP_NAME=Financial AI Agent
APP_VERSION=1.0.0
DEBUG=false
HOST=0.0.0.0
PORT=8000
